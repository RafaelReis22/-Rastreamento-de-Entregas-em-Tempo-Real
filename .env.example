# ============================================================
# VARIÁVEIS DE AMBIENTE - Rastreamento de Entregas em Tempo Real
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_AUTH_HOST=localhost
POSTGRES_AUTH_PORT=5432
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=troque_esta_senha

POSTGRES_DELIVERY_HOST=localhost
POSTGRES_DELIVERY_PORT=5433
POSTGRES_DELIVERY_DB=delivery_db
POSTGRES_DELIVERY_USER=delivery_user
POSTGRES_DELIVERY_PASSWORD=troque_esta_senha

POSTGRES_TRACKING_HOST=localhost
POSTGRES_TRACKING_PORT=5434
POSTGRES_TRACKING_DB=tracking_db
POSTGRES_TRACKING_USER=tracking_user
POSTGRES_TRACKING_PASSWORD=troque_esta_senha

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=troque_esta_senha

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── JWT ─────────────────────────────────────────────────────
# Gere com: openssl genrsa -out jwt_private.pem 2048
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# ── Serviços ─────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8081
DELIVERY_SERVICE_URL=http://localhost:8082
TRACKING_SERVICE_URL=http://localhost:8083
WEBSOCKET_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8085

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8084

# ── Notificações (preencha quando integrar) ──────────────────
# FCM_SERVER_KEY=sua_chave_fcm
# SENDGRID_API_KEY=sua_chave_sendgrid

# ── Observabilidade ──────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_ADMIN_PASSWORD=troque_esta_senha
